# Load the simulated families
data(simulated_families)
# Check the structure of the data
str(simulated_families[[1]])
names(simulated_families[[1]])
# Add Geno column if missing (simulate carrier status)
# Typically, some individuals would be carriers (Geno=1) and others non-carriers (Geno=0)
simulated_families_with_geno <- lapply(simulated_families, function(fam) {
if (!"Geno" %in% names(fam)) {
# Add Geno column - mark affected individuals as likely carriers
# and some random unaffected individuals as carriers too
fam$Geno <- ifelse(fam$isAff == 1, 1,
ifelse(runif(nrow(fam)) < 0.05, 1, 0))
}
return(fam)
})
set.seed(27)
prior_params <- list(
asymptote = list(g1 = 1, g2 = 1),
threshold = list(min = 5, max = 40),
median = list(m1 = 2, m2 = 2),
first_quartile = list(q1 = 6, q2 = 3)
)
test_output <- penetrance(
pedigree = simulated_families_with_geno[1:10],
twins = NULL,
n_chains = 1,
n_iter_per_chain = 5000,
ncores = 2,
baseline_data = baseline_data_default,
allele_freq = 0.001,
prior_params = prior_params,
burn_in = 0.1,
median_max = TRUE,
age_imputation = FALSE,
remove_proband = FALSE,
sex_specific = TRUE,
summary_stats = TRUE,
rejection_rates = TRUE,
density_plots = TRUE,
plot_trace = TRUE,
penetrance_plot = TRUE,
penetrance_plot_pdf = TRUE,
plot_loglikelihood = TRUE,
plot_acf = TRUE,
probCI = 0.95
)
# Run WITHOUT parallel processing (ncores = 1)
test_output <- penetrance(
pedigree = simulated_families_with_geno[1:5],  # Fewer families for speed
twins = NULL,
n_chains = 1,
n_iter_per_chain = 2000,  # Reduced iterations
ncores = 1,  # Run sequentially, no parallel processing
baseline_data = baseline_data_default,
allele_freq = 0.001,
prior_params = prior_params,
burn_in = 0.1,
median_max = TRUE,
age_imputation = FALSE,
remove_proband = FALSE,
sex_specific = TRUE,
summary_stats = TRUE,
rejection_rates = TRUE,
